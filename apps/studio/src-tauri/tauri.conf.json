{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vailabel Studio",
  "version": "1.0.11",
  "identifier": "com.vailabel.studio",
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vailabel Studio",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
