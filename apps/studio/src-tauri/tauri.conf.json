{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vailabel Studio",
  "version": "1.0.14",
  "identifier": "com.vailabel.studio",
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vailabel Studio",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "resources/python": "resources/python",
      "resources/runtime": "resources/runtime"
    }
  }
}
