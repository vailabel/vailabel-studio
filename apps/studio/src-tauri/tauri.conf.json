{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vailabel Studio",
  "version": "2.1.1",
  "identifier": "com.vailabel.studio",
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vailabel Studio",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/python": "resources/python",
      "resources/runtime": "resources/runtime"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vailabel/vailabel-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwQThBQkY5QTlCODU3MUIKUldRYlY3aXArYXVvUUN1MUZsbFY2ZHNKSERRM0ZJakhsNVFZc3dPbGppcGsxZ3hnRjZxcWFjUzUK"
    }
  }
}
