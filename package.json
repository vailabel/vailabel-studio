{
  "name": "vailabel",
  "version": "1.0.11",
  "description": "image labeling",
  "private": true,
  "authors": {
    "name": "Vichea Nath",
    "email": "nathvichea1@gmail.com"
  },
  "scripts": {
    "clean": "npx git-clear-branch",
    "format": "yarn workspace @vailabel/studio format && yarn workspace web format",
    "commit": "cz",
    "prepare": "husky install",
    "test": "yarn workspace @vailabel/studio test",
    "build": "yarn workspace @vailabel/studio build && yarn workspace web build",
    "dev": "yarn workspace @vailabel/studio tauri:dev",
    "studio": "yarn workspace @vailabel/studio dev",
    "desktop": "yarn workspace @vailabel/studio tauri:dev",
    "release": "yarn workspace @vailabel/studio tauri:build",
    "typecheck": "yarn workspace @vailabel/studio typecheck",
    "lint": "yarn workspace @vailabel/studio lint",
    "changeset": "changeset",
    "changeset:patch": "changeset add --empty",
    "changeset:minor": "changeset add --empty",
    "changeset:major": "changeset add --empty",
    "version": "changeset version",
    "release:patch": "yarn changeset:patch && yarn version && git push --follow-tags",
    "release:minor": "yarn changeset:minor && yarn version && git push --follow-tags",
    "release:major": "yarn changeset:major && yarn version && git push --follow-tags",
    "auto-release": "node scripts/auto-release.js",
    "release:auto": "yarn auto-release",
    "release:simple": "node scripts/simple-release.js",
    "release:now": "yarn release:simple"
  },
  "keywords": [],
  "workspaces": ["apps/studio", "apps/web"],
  "author": {
    "name": "Vichea Nath",
    "email": "nathvichea1@gmail.com"
  },
  "license": "GPL-3.0-only",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/jest": "^30.0.0",
    "@types/semver": "^7.7.0",
    "changesets": "^1.0.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {}
}
